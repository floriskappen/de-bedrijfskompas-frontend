---
import Layout from "../../layouts/Layout.astro";
import FavoritesPage from "../../components/FavoritesPage";
import { getAllCompanies } from "../../lib/company-data";
import { t } from "../../lib/i18n";

const companies = getAllCompanies();
const locale = "en";
---

<Layout title={`${t("favorites_page", locale)} — ${t("title", locale)}`}>
  <main class="surface-warm-grain min-h-screen">
    <FavoritesPage client:only="react" companies={companies} locale={locale} />
  </main>
</Layout>
