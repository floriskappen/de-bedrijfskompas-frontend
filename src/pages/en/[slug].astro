---
import Layout from "../../layouts/Layout.astro";
import { getAllCompanies, getCompanyById } from "../../lib/company-data";
import CompanyDetail from "../../components/CompanyDetail";

export async function getStaticPaths() {
  const companies = getAllCompanies();
  return companies.map((c) => ({
    params: { slug: c.company_id },
  }));
}

const { slug } = Astro.params;
const company = getCompanyById(slug);

if (!company) {
  return Astro.redirect("/404");
}

const locale = "en";
---

<Layout title={`${company.name.toLowerCase()} — de bedrijfskompas`}>
  <main class="surface-warm-grain min-h-screen text-ink">
    <CompanyDetail company={company} locale={locale} client:load />
  </main>
  <!-- paper-bloom reveal: opens from the bottom (where the peek card was) -->
  <div class="bloom-curtain is-revealing" aria-hidden="true"></div>
</Layout>
