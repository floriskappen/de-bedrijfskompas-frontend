---
import type { Company } from "../lib/company-data/types";
import { t } from "../lib/i18n";
import MapView from "./MapView";
import PeekCard from "./PeekCard";

interface Props {
  companies: Company[];
  locale: "nl" | "en";
}

const { companies, locale } = Astro.props;

// fail the build if MAPBOX_PUBLIC_TOKEN is missing
const mapboxToken = import.meta.env.MAPBOX_PUBLIC_TOKEN || process.env.MAPBOX_PUBLIC_TOKEN;
if (!mapboxToken) {
  throw new Error("MAPBOX_PUBLIC_TOKEN is required to build the application.");
}
---

<!-- Decide before the surface paints whether to skip the first-load reveal.
     Set by the bloom curtain when arriving back here from the detail page. -->
<script is:inline>
  try {
    if (sessionStorage.getItem("bloom-nav")) {
      document.documentElement.classList.add("skip-map-reveal");
      sessionStorage.removeItem("bloom-nav");
    }
  } catch (e) {}
</script>

<div
  id="map-reveal-surface"
  class="map-reveal-surface relative w-screen h-screen overflow-hidden bg-paper flex flex-col"
>
  <!-- map widget -->
  <div class="absolute inset-0 z-0">
    <MapView client:only="react" companies={companies} mapboxToken={mapboxToken} locale={locale} />
  </div>

  <!-- quiet empty state overlay -->
  {
    companies.length === 0 && (
      <div
        id="empty-state-overlay"
        class="absolute inset-0 z-10 flex items-center justify-center bg-paper/80 pointer-events-none"
      >
        <div class="ontwerp-card p-6 text-center pointer-events-auto">
          <p class="font-mono text-[11px] text-ink-soft">
            {t("empty_state", locale)}
          </p>
        </div>
      </div>
    )
  }

  <!-- peek card overlay — padded so the card floats with air on every side -->
  <div class="absolute bottom-0 inset-x-0 z-20 p-3 sm:p-4 pointer-events-none">
    <PeekCard client:load companies={companies} locale={locale} />
  </div>
</div>
