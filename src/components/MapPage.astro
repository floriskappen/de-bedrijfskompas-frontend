---
import type { Company } from "../lib/company-data/types";
import { t } from "../lib/i18n";
import MapView from "./MapView";
import PeekCard from "./PeekCard";
import LanguageSwitcher from "./LanguageSwitcher";

interface Props {
  companies: Company[];
  locale: "nl" | "en";
}

const { companies, locale } = Astro.props;

// fail the build if MAPBOX_PUBLIC_TOKEN is missing
const mapboxToken = import.meta.env.MAPBOX_PUBLIC_TOKEN || process.env.MAPBOX_PUBLIC_TOKEN;
if (!mapboxToken) {
  throw new Error("MAPBOX_PUBLIC_TOKEN is required to build the application.");
}
---

<div
  id="map-reveal-surface"
  class="map-reveal-surface relative w-screen h-screen overflow-hidden bg-paper flex flex-col"
>
  <!-- map widget -->
  <div class="absolute inset-0 z-0">
    <MapView client:only="react" companies={companies} mapboxToken={mapboxToken} />
  </div>

  <!-- quiet empty state overlay -->
  {
    companies.length === 0 && (
      <div
        id="empty-state-overlay"
        class="absolute inset-0 z-10 flex items-center justify-center bg-paper/80 pointer-events-none"
      >
        <div class="p-6 bg-paper-card border border-ink text-center pointer-events-auto">
          <p class="font-mono text-[11px] tracking-[0.08em] uppercase text-ink-soft">
            {t("empty_state", locale)}
          </p>
        </div>
      </div>
    )
  }

  <!-- top-right filters pill (inert) -->
  <button
    id="filters-pill"
    type="button"
    aria-label={t("filters", locale)}
    class="absolute top-4 right-28 z-20 inline-flex h-10 items-center gap-2 border border-ink bg-paper px-3.5 font-mono text-[11px] tracking-[0.08em] uppercase text-ink hover:bg-paper-card cursor-default"
  >
    <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <path d="M1 3h12M3 7h8M5 11h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    </svg>
    {t("filters", locale)}
  </button>

  <!-- language switcher overlay -->
  <div class="absolute top-4 right-4 z-20">
    <LanguageSwitcher client:load locale={locale} />
  </div>

  <!-- peek card overlay -->
  <div class="absolute bottom-0 inset-x-0 z-20 pointer-events-none">
    <PeekCard client:load companies={companies} locale={locale} />
  </div>
</div>
