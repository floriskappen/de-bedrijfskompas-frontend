---
import type { AxisId } from "../lib/company-data/types";
import { AXIS_IDS } from "../lib/company-data/types";
import { getAxisLabel } from "../lib/i18n/labels";
import { getAxisInfoHref } from "../lib/company-data/axis-detail";
import {
  getAxisContent,
  getAxisSections,
  getAxisNumber,
  footnoteNumbers,
} from "../lib/i18n/info-content";
import { t } from "../lib/i18n";
import AxisGlyph from "./AxisGlyph.astro";
import ProseP from "./ProseP.astro";
import Footnotes from "./Footnotes.astro";
import Disclaimer from "./Disclaimer.astro";

interface Props {
  axis: AxisId;
  locale: "nl" | "en";
}

const { axis, locale } = Astro.props;

const label = getAxisLabel(axis, locale);
const content = getAxisContent(axis, locale);
const sections = getAxisSections(locale);
const number = getAxisNumber(axis);
const numbers = footnoteNumbers(content.footnotes);

const base = locale === "en" ? "/en/" : "/";
const philosophyHref = locale === "en" ? "/en/about/" : "/over/";
const otherAxes = AXIS_IDS.filter((a) => a !== axis);

// how readable this axis is, on a small three-dot scale
const readabilityFill = { high: 3, medium: 2, low: 1 }[content.readability];
const readabilityLabel = sections.readabilityPhrase[content.readability];
---

<main class="surface-warm-grain min-h-screen text-ink">
  <article class="mx-auto w-full max-w-xl px-6 pb-24 pt-5">
    <!-- top bar: back (to the company you came from, else the map) -->
    <div class="mb-10 flex items-center justify-between">
      <a id="info-back" href={base} class="ontwerp-button h-9">
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path
            d="M9 2 L 4 7 L 9 12"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <span id="info-back-label">{t("back_to_map", locale)}</span>
      </a>
      <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-ink-quiet">
        {sections.axisEyebrow(number)}
      </span>
    </div>

    <!-- header: glyph + axis name + plain-words lead -->
    <div class="flex items-center gap-3.5">
      <AxisGlyph axis={axis} size={30} />
      <h1 class="font-sans text-[40px] leading-none text-ink normal-case">{label}</h1>
    </div>
    <p class="mt-5 font-sans text-[20px] leading-snug text-ink-soft">{content.plain}</p>

    <!-- what it means -->
    <section class="mt-10">
      <h2 class="font-mono text-[10px] uppercase tracking-[0.16em] text-ink-quiet">
        {sections.meaning}
      </h2>
      <div class="mt-3 space-y-3.5">
        {content.meaning.map((p) => <ProseP text={p} numbers={numbers} />)}
      </div>
    </section>

    <!-- what counts -->
    <section class="mt-9">
      <h2 class="font-mono text-[10px] uppercase tracking-[0.16em] text-ink-quiet">
        {sections.counts}
      </h2>
      <div class="mt-3 space-y-3.5">
        {content.counts.map((p) => <ProseP text={p} numbers={numbers} />)}
      </div>
    </section>

    <!-- silence -->
    <section class="mt-9">
      <h2 class="font-mono text-[10px] uppercase tracking-[0.16em] text-ink-quiet">
        {sections.silence}
      </h2>
      <div class="mt-3 space-y-3.5">
        {content.silence.map((p) => <ProseP text={p} numbers={numbers} />)}
      </div>
    </section>

    <!-- readability: a small three-dot scale -->
    <div class="mt-9 flex items-center gap-2.5 border-t border-ink/10 pt-4">
      <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-ink-quiet">
        {sections.readability}
      </span>
      <span class="flex items-center gap-1" aria-hidden="true">
        {[1, 2, 3].map((i) => (
          <span
            class:list={[
              "h-[7px] w-[7px] rounded-full",
              i <= readabilityFill ? "bg-accent-base" : "border border-border-quiet",
            ]}
          ></span>
        ))}
      </span>
      <span class="font-sans text-[13px] text-ink-quiet">{readabilityLabel}</span>
    </div>

    <!-- the other axes -->
    <section class="mt-12">
      <h2 class="font-mono text-[10px] uppercase tracking-[0.16em] text-ink-quiet">
        {sections.otherAxes}
      </h2>
      <div class="mt-2 divide-y divide-ink/10 border-y border-ink/10">
        {otherAxes.map((a) => (
          <a
            href={getAxisInfoHref(a, locale)}
            class="flex items-center gap-3.5 py-3 no-underline"
          >
            <AxisGlyph axis={a} size={20} tone="quiet" />
            <span class="min-w-0 flex-1 font-sans text-[18px] leading-none text-ink normal-case">
              {getAxisLabel(a, locale)}
            </span>
            <svg width="11" height="11" viewBox="0 0 11 11" class="shrink-0 text-ink-quiet" aria-hidden="true">
              <path
                d="M3 2 L 8 5.5 L 3 9"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
                stroke-linejoin="round"
                fill="none"></path>
            </svg>
          </a>
        ))}
      </div>
    </section>

    <!-- philosophy link — a plain inline link with the same out-arrow as the
         detail page's axis "uitleg" link, on the right -->
    <div class="mt-9 flex justify-center">
      <a href={philosophyHref} class="inline-flex items-center gap-1.5 text-ink underline">
        {sections.philosophyLink}
        <svg width="11" height="11" viewBox="0 0 11 11" class="shrink-0 text-ink-quiet no-underline" aria-hidden="true">
          <path
            d="M3 8 L 8 3 M 4.5 3 L 8 3 L 8 6.5"
            stroke="currentColor"
            stroke-width="1.3"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"></path>
        </svg>
      </a>
    </div>

    {content.footnotes && <Footnotes footnotes={content.footnotes} />}

    <Disclaimer locale={locale} withBorder={!content.footnotes} />
  </article>
</main>

<!-- diagonal paper-bloom sweep, lower-left to upper-right, on every load -->
<div class="bloom-curtain is-revealing-sweep" aria-hidden="true"></div>

<script>
  // The back button is origin-aware via ?from=. A company id returns to that
  // company's detail page; the reserved value "filters" returns to the map with
  // the filter sheet reopened (?filters=open); absent, it falls back to the map.
  const params = new URLSearchParams(window.location.search);
  const from = params.get("from");
  if (from) {
    const isEn = window.location.pathname.startsWith("/en/");
    const mapBase = isEn ? "/en/" : "/";
    const back = document.getElementById("info-back");
    const label = document.getElementById("info-back-label");
    if (from === "filters") {
      if (back) back.setAttribute("href", `${mapBase}?filters=open`);
    } else {
      if (back) back.setAttribute("href", `${mapBase}${encodeURIComponent(from)}/`);
      if (label) label.textContent = isEn ? "back" : "terug";
    }
  }
</script>
